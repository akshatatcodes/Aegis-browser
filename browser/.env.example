# Aegis Browser — Environment Variables
# Copy this file to .env and fill in your values

# Core backend API (Express server)
CORE_API_URL=http://localhost:3001

# Local proxy port (browser traffic routes here)
LOCAL_PROXY_PORT=8118

# Session duration before identity rotation (milliseconds)
SESSION_DURATION_MS=2700000

# Enable dev tools in browser windows (true/false)
DEVTOOLS_ENABLED=false

# Log level: error | warn | info | debug
LOG_LEVEL=info
