{
  "name": "aegis-browser",
  "version": "1.0.0",
  "description": "Aegis Privacy Network — Adaptive Electron Browser",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder"
  },
  "dependencies": {
    "axios": "^1.6.7",
    "express": "^4.18.2",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.9.1",
    "@babel/core": "^7.23.9",
    "@babel/preset-react": "^7.23.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "build": {
    "appId": "com.aegis.browser",
    "productName": "Aegis Browser",
    "directories": {
      "output": "dist"
    },
    "mac": {
      "category": "public.app-category.utilities"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "keywords": ["privacy", "anonymity", "onion-routing", "browser"],
  "author": "Aegis Project",
  "license": "MIT"
}
